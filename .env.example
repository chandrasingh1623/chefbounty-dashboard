# Copy this file to .env and fill in your values

# Database connection
DATABASE_URL=postgresql://user:password@localhost:5432/chefbounty

# Email service
RESEND_API_KEY=your-resend-api-key

# Authentication
JWT_SECRET=your-secure-jwt-secret
APP_URL=http://localhost:3001

# OAuth - LinkedIn (optional)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Set to true for local development without real OAuth
MOCK_OAUTH=false
DISABLE_WEBSOCKET=false

# Admin notification emails (comma-separated)
ADMIN_EMAILS=admin@example.com

# Environment
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3001
